#!/usr/bin/env bash
set -euo pipefail

TASK="${1:-}"
if [ -z "$TASK" ]; then
  echo "usage: ntm-crush-session <task>" >&2
  exit 64
fi

SESSION="crush-${PWD##*/}"

CMD="cd '$PWD' && direnv allow . && direnv exec . crush '$TASK'"

if tmux has-session -t "$SESSION" 2>/dev/null; then
  tmux send-keys -t "$SESSION" "$CMD" C-m
else
  tmux new-session -d -s "$SESSION" "$CMD"
fi

echo "session: $SESSION"