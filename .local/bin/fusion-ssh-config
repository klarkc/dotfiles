#!/usr/bin/env bash
set -euo pipefail

output="${HOME}/.fusion/ssh_config"
mkdir -p "$(dirname "$output")"

{
  echo '# Generated by fusion-ssh-config. Do not edit manually.'
  echo '# System SSH snippets are flattened here instead of Included because'
  echo '# OpenSSH rejects some system config paths inside sandboxed user units.'
  echo

  if [ -d /etc/ssh/ssh_config.d ]; then
    for file in /etc/ssh/ssh_config.d/*.conf; do
      [ -e "$file" ] || continue
      real_file="$(readlink -f "$file")"
      if [ -n "$real_file" ] && [ -r "$real_file" ]; then
        printf '# BEGIN %s\n' "$real_file"
        cat "$real_file"
        printf '\n# END %s\n\n' "$real_file"
      fi
    done
  fi

  if [ -r "${HOME}/.ssh/config" ]; then
    printf '# BEGIN %s/.ssh/config\n' "$HOME"
    cat "${HOME}/.ssh/config"
    printf '\n# END %s/.ssh/config\n\n' "$HOME"
  fi

  echo 'Host *'
  echo '    SendEnv LANG LC_*'
  echo '    HashKnownHosts yes'
} > "$output"

chmod 0644 "$output"
echo "Generated $output"
