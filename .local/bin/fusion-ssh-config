#!/usr/bin/env bash
set -euo pipefail

output="${HOME}/.fusion/ssh_config"
mkdir -p "$(dirname "$output")"

{
  echo '# Generated by fusion-ssh-config. Do not edit manually.'
  echo '# This resolves /etc/ssh/ssh_config.d symlinks so OpenSSH can read'
  echo '# system SSH snippets from Fusion systemd sandbox namespaces.'
  echo

  if [ -d /etc/ssh/ssh_config.d ]; then
    for file in /etc/ssh/ssh_config.d/*.conf; do
      [ -e "$file" ] || continue
      real_file="$(readlink -f "$file")"
      if [ -n "$real_file" ] && [ -r "$real_file" ]; then
        printf 'Include %s\n' "$real_file"
      fi
    done
    echo
  fi

  if [ -r "${HOME}/.ssh/config" ]; then
    printf 'Include %s/.ssh/config\n\n' "$HOME"
  fi

  echo 'Host *'
  echo '    SendEnv LANG LC_*'
  echo '    HashKnownHosts yes'
} > "$output"

chmod 0644 "$output"
echo "Generated $output"
