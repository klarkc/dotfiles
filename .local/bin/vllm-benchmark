#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: vllm-benchmark [--check]

Runs lightweight target-aware HTTP benchmarks against the active vLLM
OpenAI-compatible chat endpoint. Start a model first with vllm-config.

Environment overrides:
  VLLM_BENCHMARK_ENV  Path to benchmark.env from a vLLM runtime cache
  SMALL_PROMPTS       Default: 4
  SMALL_INPUT_LEN     Default: 1024
  SMALL_OUTPUT_LEN    Default: 32
  MEDIUM_PROMPTS      Default: 4
  MEDIUM_INPUT_LEN    Default: 4096
  MEDIUM_OUTPUT_LEN   Default: 64
  LONG_PROMPTS        Default: 2
  LONG_INPUT_LEN      Default: 48000
  LONG_OUTPUT_LEN     Default: 64
EOF
}

check_only=0
case "${1:-}" in
  -h|--help) usage; exit 0 ;;
  --check) check_only=1 ;;
  "") ;;
  *) echo "Unknown argument: $1" >&2; usage >&2; exit 2 ;;
esac

find_benchmark_env() {
  local latest
  if [ -n "${VLLM_BENCHMARK_ENV:-}" ] && [ -r "$VLLM_BENCHMARK_ENV" ]; then
    printf '%s\n' "$VLLM_BENCHMARK_ENV"
    return 0
  fi
  latest="$(ls -t "$HOME"/.cache/vllm-*/benchmark.env 2>/dev/null | head -n 1 || true)"
  if [ -n "$latest" ] && [ -r "$latest" ]; then
    printf '%s\n' "$latest"
    return 0
  fi
  echo "No vLLM benchmark.env found. Start a model first with: vllm-config qwen3.6-35B-a3b" >&2
  return 1
}

load_env_key() {
  local env_file="$1"
  local key="$2"
  local line value
  line="$(grep -E "^${key}=" "$env_file" | tail -n 1 || true)"
  [ -n "$line" ] || return 0
  value="${line#*=}"
  value="${value%\"}"
  value="${value#\"}"
  printf -v "$key" '%s' "$value"
  export "$key"
}

redact_file() {
  local src="$1"
  local dst="$2"
  if [ -r "$src" ]; then
    sed -E \
      -e 's/(VLLM_API_KEY=).*/\1<redacted>/' \
      -e 's/(HF_TOKEN=).*/\1<redacted>/' \
      -e 's/(HF_HUB_TOKEN=).*/\1<redacted>/' \
      -e 's/(HUGGING_FACE_HUB_TOKEN=).*/\1<redacted>/' \
      "$src" > "$dst"
  fi
}

metric_value() {
  local key="$1"
  local file="$2"
  python3 - "$key" "$file" <<'PY'
import json, sys
key, path = sys.argv[1:]
with open(path, 'r', encoding='utf-8') as f:
    data = json.load(f)
value = data.get(key, '')
print(value if value is not None else '')
PY
}

write_summary() {
  local name="$1"
  local slug="$2"
  local file="$artifact_dir/${slug}.json"
  local out="$artifact_dir/${slug}.summary.env"
  local duration input_tokens output_tokens req_tps prefill_tps decode_tps total_tps mean_ttft p99_ttft mean_tpot failed

  duration="$(metric_value duration_s "$file")"
  input_tokens="$(metric_value total_prompt_tokens "$file")"
  output_tokens="$(metric_value total_completion_tokens "$file")"
  req_tps="$(metric_value request_tps "$file")"
  prefill_tps="$(metric_value prefill_tps "$file")"
  decode_tps="$(metric_value decode_tps "$file")"
  total_tps="$(metric_value total_tps "$file")"
  mean_ttft="$(metric_value mean_ttft_ms "$file")"
  p99_ttft="$(metric_value p99_ttft_ms "$file")"
  mean_tpot="$(metric_value mean_tpot_ms "$file")"
  failed="$(metric_value failed_requests "$file")"

  {
    echo "name=$name"
    echo "served_model=$MODEL"
    echo "base_url=$BASE_URL"
    echo "max_concurrency=2"
    echo "duration_s=$duration"
    echo "input_tokens=$input_tokens"
    echo "output_tokens=$output_tokens"
    echo "failed_requests=$failed"
    echo "request_tps=$req_tps"
    echo "prefill_tps=$prefill_tps"
    echo "decode_tps=$decode_tps"
    echo "total_tps=$total_tps"
    echo "mean_ttft_ms=$mean_ttft"
    echo "p99_ttft_ms=$p99_ttft"
    echo "mean_tpot_ms=$mean_tpot"
  } > "$out"

  cat <<EOF

--- $name metrics ---
failed_requests=${failed:-n/a}
request_tps=${req_tps:-n/a}
prefill_tps=${prefill_tps:-n/a}
decode_tps=${decode_tps:-n/a}
total_tps=${total_tps:-n/a}
mean_ttft_ms=${mean_ttft:-n/a}
p99_ttft_ms=${p99_ttft:-n/a}
mean_tpot_ms=${mean_tpot:-n/a}
EOF
}

capture_metadata() {
  {
    echo "timestamp=$timestamp"
    echo "benchmark_env=$benchmark_env"
    echo "instance=$instance"
    echo "instance_env=$instance_env"
    echo "served_model=$MODEL"
    echo "base_url=$BASE_URL"
    echo "max_concurrency=2"
    echo "small_requests=prompts:${SMALL_PROMPTS},input:${SMALL_INPUT_LEN},output:${SMALL_OUTPUT_LEN}"
    echo "medium_requests=prompts:${MEDIUM_PROMPTS},input:${MEDIUM_INPUT_LEN},output:${MEDIUM_OUTPUT_LEN}"
    echo "long_context_requests=prompts:${LONG_PROMPTS},input:${LONG_INPUT_LEN},output:${LONG_OUTPUT_LEN}"
  } > "$artifact_dir/metadata.env"

  systemctl --user --no-pager -l status "vllm@${instance}.service" fusion.service > "$artifact_dir/systemd-status.txt" 2>&1 || true
  journalctl --user-unit "vllm@${instance}.service" -n 700 --no-pager -o short-iso > "$artifact_dir/journal-vllm.txt" 2>&1 || true
  journalctl --user-unit fusion.service -n 300 --no-pager -o short-iso > "$artifact_dir/journal-fusion.txt" 2>&1 || true
  nvidia-smi > "$artifact_dir/nvidia-smi.txt" 2>&1 || true
  ps -eo pid,ppid,stat,pcpu,pmem,rss,vsz,args | grep -E 'vllm|fusion|tmux' | grep -v grep > "$artifact_dir/processes.txt" 2>&1 || true
  [ ! -r "$HOME/.cache/vllm-${instance}/runtime_command.sh" ] || cp "$HOME/.cache/vllm-${instance}/runtime_command.sh" "$artifact_dir/runtime_command.sh"
  redact_file "$benchmark_env" "$artifact_dir/benchmark.env"
  redact_file "$instance_env" "$artifact_dir/model.env"
}

finish_archive() {
  local run_status="$1"
  echo "$run_status" > "$artifact_dir/status.txt"
  capture_metadata
  tar -C "$artifact_root" -czf "$archive" "$(basename "$artifact_dir")"
  echo
  echo "Benchmark artifact: $archive"
}

run_case() {
  local name="$1"
  local slug="$2"
  local num_prompts="$3"
  local input_len="$4"
  local output_len="$5"
  local json_file="$artifact_dir/${slug}.json"
  local log_file="$artifact_dir/${slug}.log"

  echo
  echo "=== $name ==="
  echo "served_model=$MODEL base_url=$BASE_URL prompts=$num_prompts concurrency=2 input=$input_len output=$output_len"
  set +e
  python3 - "$BASE_URL" "$MODEL" "${VLLM_API_KEY:-}" "$num_prompts" "$input_len" "$output_len" "$json_file" <<'PY' 2>&1 | tee "$log_file"
import concurrent.futures
import json
import statistics
import sys
import time
import urllib.error
import urllib.request

base_url, model, api_key, prompts, input_len, output_len, out_path = sys.argv[1:]
prompts = int(prompts)
input_len = int(input_len)
output_len = int(output_len)
max_workers = min(2, prompts)
unit = 'Benchmark token. '
prompt = (unit * ((input_len // 3) + 2))[: input_len * 6]

def percentile(values, pct):
    if not values:
        return None
    values = sorted(values)
    index = min(len(values) - 1, max(0, int(round((pct / 100) * (len(values) - 1)))))
    return values[index]

def request_one(index):
    payload = {
        'model': model,
        'messages': [{'role': 'user', 'content': prompt}],
        'temperature': 0,
        'max_tokens': output_len,
        'stream': True,
        'stream_options': {'include_usage': True},
    }
    req = urllib.request.Request(
        base_url.rstrip('/') + '/chat/completions',
        data=json.dumps(payload).encode(),
        headers={
            'Content-Type': 'application/json',
            'Authorization': 'Bearer ' + api_key,
        },
    )
    t0 = time.perf_counter()
    first = None
    chunks = 0
    chars = 0
    usage = {}
    try:
        with urllib.request.urlopen(req, timeout=3600) as response:
            for raw in response:
                if not raw.startswith(b'data: '):
                    continue
                data = raw[6:].strip()
                if data == b'[DONE]':
                    break
                obj = json.loads(data)
                if obj.get('usage'):
                    usage = obj['usage']
                choices = obj.get('choices') or []
                if not choices:
                    continue
                delta = choices[0].get('delta') or {}
                text = (
                    delta.get('content')
                    or delta.get('reasoning_content')
                    or delta.get('reasoning')
                    or delta.get('tool_calls')
                    or ''
                )
                if text:
                    if first is None:
                        first = time.perf_counter()
                    chunks += 1
                    chars += len(text) if isinstance(text, str) else len(json.dumps(text))
        t1 = time.perf_counter()
        completion_tokens = usage.get('completion_tokens') or max(1, chars // 4)
        prompt_tokens = usage.get('prompt_tokens') or input_len
        return {
            'request': index,
            'ok': True,
            'prompt_tokens': prompt_tokens,
            'completion_tokens': completion_tokens,
            'ttft_s': None if first is None else first - t0,
            'total_s': t1 - t0,
            'chunks': chunks,
        }
    except Exception as exc:
        t1 = time.perf_counter()
        return {
            'request': index,
            'ok': False,
            'error': repr(exc),
            'total_s': t1 - t0,
        }

start = time.perf_counter()
with concurrent.futures.ThreadPoolExecutor(max_workers=max_workers) as pool:
    results = list(pool.map(request_one, range(1, prompts + 1)))
end = time.perf_counter()

ok = [r for r in results if r.get('ok')]
failed = [r for r in results if not r.get('ok')]
duration = end - start
prompt_tokens = sum(int(r.get('prompt_tokens') or 0) for r in ok)
completion_tokens = sum(int(r.get('completion_tokens') or 0) for r in ok)
ttfts = [float(r['ttft_s']) * 1000 for r in ok if r.get('ttft_s') is not None]
tpots = []
for r in ok:
    ttft = r.get('ttft_s')
    total = float(r.get('total_s') or 0)
    completion = int(r.get('completion_tokens') or 0)
    if ttft is not None and completion > 1 and total > ttft:
        tpots.append(((total - ttft) / max(1, completion - 1)) * 1000)

summary = {
    'model': model,
    'num_prompts': prompts,
    'max_concurrency': max_workers,
    'requested_input_len': input_len,
    'requested_output_len': output_len,
    'duration_s': round(duration, 3),
    'successful_requests': len(ok),
    'failed_requests': len(failed),
    'total_prompt_tokens': prompt_tokens,
    'total_completion_tokens': completion_tokens,
    'request_tps': round(len(ok) / max(0.001, duration), 4),
    'prefill_tps': round(prompt_tokens / max(0.001, duration), 2),
    'decode_tps': round(completion_tokens / max(0.001, duration), 2),
    'total_tps': round((prompt_tokens + completion_tokens) / max(0.001, duration), 2),
    'mean_ttft_ms': None if not ttfts else round(statistics.mean(ttfts), 2),
    'p99_ttft_ms': None if not ttfts else round(percentile(ttfts, 99), 2),
    'mean_tpot_ms': None if not tpots else round(statistics.mean(tpots), 2),
    'results': results,
}
with open(out_path, 'w', encoding='utf-8') as f:
    json.dump(summary, f, indent=2)
    f.write('\n')
print(json.dumps({k: v for k, v in summary.items() if k != 'results'}, indent=2))
if failed:
    print('Failed requests:', json.dumps(failed[:3], indent=2), file=sys.stderr)
    raise SystemExit(1)
PY
  local rc="${PIPESTATUS[0]}"
  set -e
  echo "$rc" > "$artifact_dir/${slug}.exit-code"
  if [ "$rc" -eq 0 ]; then
    write_summary "$name" "$slug"
  fi
  return "$rc"
}

benchmark_env="$(find_benchmark_env)"
load_env_key "$benchmark_env" BASE_URL
load_env_key "$benchmark_env" MODEL
load_env_key "$benchmark_env" VLLM_API_KEY

instance="$(basename "$(dirname "$benchmark_env")")"
instance="${instance#vllm-}"
instance_env="$HOME/.config/vllm/${instance}.env"

BASE_URL="${BASE_URL:-http://127.0.0.1:8000/v1}"
BASE_URL="${BASE_URL%/}"
MODEL="${MODEL:-}"
if [ -z "$MODEL" ]; then
  echo "MODEL missing from $benchmark_env" >&2
  exit 1
fi

if [ "$check_only" -eq 1 ]; then
  python3 - "$BASE_URL" "${VLLM_API_KEY:-}" <<'PY'
import json, sys, urllib.request
base_url, api_key = sys.argv[1:]
req = urllib.request.Request(
    base_url.rstrip('/') + '/models',
    headers={'Authorization': 'Bearer ' + api_key},
)
with urllib.request.urlopen(req, timeout=30) as response:
    data = json.load(response)
print(json.dumps(data, indent=2)[:2000])
PY
  exit 0
fi

SMALL_PROMPTS="${SMALL_PROMPTS:-4}"
SMALL_INPUT_LEN="${SMALL_INPUT_LEN:-1024}"
SMALL_OUTPUT_LEN="${SMALL_OUTPUT_LEN:-32}"
MEDIUM_PROMPTS="${MEDIUM_PROMPTS:-4}"
MEDIUM_INPUT_LEN="${MEDIUM_INPUT_LEN:-4096}"
MEDIUM_OUTPUT_LEN="${MEDIUM_OUTPUT_LEN:-64}"
LONG_PROMPTS="${LONG_PROMPTS:-2}"
LONG_INPUT_LEN="${LONG_INPUT_LEN:-48000}"
LONG_OUTPUT_LEN="${LONG_OUTPUT_LEN:-64}"

timestamp="$(date +%Y%m%d-%H%M%S)"
artifact_root="$HOME/.cache/vllm-benchmarks"
artifact_dir="$artifact_root/${timestamp}-${instance}"
archive="$artifact_dir.tar.gz"
mkdir -p "$artifact_dir"
trap 'finish_archive interrupted; exit 130' INT TERM

redact_file "$benchmark_env" "$artifact_dir/benchmark.env"
redact_file "$instance_env" "$artifact_dir/model.env"

echo "Using benchmark env: $benchmark_env"
echo "Benchmark artifact directory: $artifact_dir"

status=success
run_case "Small requests" "small-requests" "$SMALL_PROMPTS" "$SMALL_INPUT_LEN" "$SMALL_OUTPUT_LEN" || status=failed
if [ "$status" = success ]; then
  run_case "Medium requests" "medium-requests" "$MEDIUM_PROMPTS" "$MEDIUM_INPUT_LEN" "$MEDIUM_OUTPUT_LEN" || status=failed
fi
if [ "$status" = success ]; then
  run_case "Long-context requests" "long-context-requests" "$LONG_PROMPTS" "$LONG_INPUT_LEN" "$LONG_OUTPUT_LEN" || status=failed
fi

finish_archive "$status"
[ "$status" = success ]
