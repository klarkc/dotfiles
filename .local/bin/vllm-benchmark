#!/usr/bin/env bash
set -euo pipefail

find_nix() {
  for candidate in "$HOME/.nix-profile/bin/nix" /nix/var/nix/profiles/default/bin/nix /run/current-system/sw/bin/nix /usr/bin/nix; do
    [ -x "$candidate" ] && { printf '%s\n' "$candidate"; return 0; }
  done
  echo "nix executable not found" >&2
  return 127
}

find_benchmark_env() {
  local latest
  if [ -n "${VLLM_BENCHMARK_ENV:-}" ] && [ -r "$VLLM_BENCHMARK_ENV" ]; then
    printf '%s\n' "$VLLM_BENCHMARK_ENV"
    return 0
  fi
  latest="$(ls -t "$HOME"/.cache/vllm-*/benchmark.env 2>/dev/null | head -n 1 || true)"
  if [ -n "$latest" ] && [ -r "$latest" ]; then
    printf '%s\n' "$latest"
    return 0
  fi
  echo "No vLLM benchmark.env found. Start a model first with: vllm-config qwen3.6-27B" >&2
  return 1
}

load_env_key() {
  local env_file="$1"
  local key="$2"
  local line value
  line="$(grep -E "^${key}=" "$env_file" | tail -n 1 || true)"
  [ -n "$line" ] || return 0
  value="${line#*=}"
  value="${value%\"}"
  value="${value#\"}"
  printf -v "$key" '%s' "$value"
  export "$key"
}

redact_file() {
  local src="$1"
  local dst="$2"
  if [ -r "$src" ]; then
    sed -E \
      -e 's/(VLLM_API_KEY=).*/\1<redacted>/' \
      -e 's/(HF_TOKEN=).*/\1<redacted>/' \
      -e 's/(HF_HUB_TOKEN=).*/\1<redacted>/' \
      -e 's/(HUGGING_FACE_HUB_TOKEN=).*/\1<redacted>/' \
      "$src" > "$dst"
  fi
}

metric_value() {
  local label="$1"
  local file="$2"
  awk -F: -v label="$label" '$1 == label {gsub(/^[[:space:]]+|[[:space:]]+$/, "", $2); print $2; found=1} END {if (!found) exit 1}' "$file" 2>/dev/null | tail -n 1 || true
}

write_summary() {
  local name="$1"
  local slug="$2"
  local file="$artifact_dir/${slug}.log"
  local out="$artifact_dir/${slug}.summary.env"
  local duration input_tokens output_tokens req_tps output_tps total_tps mean_ttft median_ttft p99_ttft mean_tpot mean_itl prefill_tps

  duration="$(metric_value 'Benchmark duration (s)' "$file")"
  input_tokens="$(metric_value 'Total input tokens' "$file")"
  output_tokens="$(metric_value 'Total generated tokens' "$file")"
  req_tps="$(metric_value 'Request throughput (req/s)' "$file")"
  output_tps="$(metric_value 'Output token throughput (tok/s)' "$file")"
  total_tps="$(metric_value 'Total Token throughput (tok/s)' "$file")"
  mean_ttft="$(metric_value 'Mean TTFT (ms)' "$file")"
  median_ttft="$(metric_value 'Median TTFT (ms)' "$file")"
  p99_ttft="$(metric_value 'P99 TTFT (ms)' "$file")"
  mean_tpot="$(metric_value 'Mean TPOT (ms)' "$file")"
  mean_itl="$(metric_value 'Mean ITL (ms)' "$file")"

  prefill_tps=""
  if [ -n "$duration" ] && [ -n "$input_tokens" ]; then
    prefill_tps="$(awk -v tokens="$input_tokens" -v seconds="$duration" 'BEGIN {if (seconds > 0) printf "%.2f", tokens / seconds}')"
  fi

  {
    echo "name=$name"
    echo "served_model=$MODEL"
    echo "tokenizer=$TOKENIZER"
    echo "base_url=$BASE_URL"
    echo "max_concurrency=2"
    echo "duration_s=$duration"
    echo "input_tokens=$input_tokens"
    echo "output_tokens=$output_tokens"
    echo "request_tps=$req_tps"
    echo "prefill_tps=$prefill_tps"
    echo "decode_tps=$output_tps"
    echo "total_tps=$total_tps"
    echo "mean_ttft_ms=$mean_ttft"
    echo "median_ttft_ms=$median_ttft"
    echo "p99_ttft_ms=$p99_ttft"
    echo "mean_tpot_ms=$mean_tpot"
    echo "mean_itl_ms=$mean_itl"
  } > "$out"

  cat <<EOF

--- $name metrics ---
request_tps=${req_tps:-n/a}
prefill_tps=${prefill_tps:-n/a}
decode_tps=${output_tps:-n/a}
total_tps=${total_tps:-n/a}
mean_ttft_ms=${mean_ttft:-n/a}
p99_ttft_ms=${p99_ttft:-n/a}
mean_tpot_ms=${mean_tpot:-n/a}
mean_itl_ms=${mean_itl:-n/a}
EOF
}

capture_metadata() {
  {
    echo "timestamp=$timestamp"
    echo "benchmark_env=$benchmark_env"
    echo "instance=$instance"
    echo "instance_env=$instance_env"
    echo "served_model=$MODEL"
    echo "tokenizer=$TOKENIZER"
    echo "base_url=$BASE_URL"
    echo "runtime=$runtime"
    echo "vllm_nix_config=$VLLM_NIX_CONFIG"
    echo "max_concurrency=2"
    echo "small_requests=prompts:${SMALL_PROMPTS},input:${SMALL_INPUT_LEN},output:${SMALL_OUTPUT_LEN}"
    echo "medium_requests=prompts:${MEDIUM_PROMPTS},input:${MEDIUM_INPUT_LEN},output:${MEDIUM_OUTPUT_LEN}"
    echo "long_context_requests=prompts:${LONG_PROMPTS},input:${LONG_INPUT_LEN},output:${LONG_OUTPUT_LEN}"
  } > "$artifact_dir/metadata.env"

  systemctl --user --no-pager -l status "vllm@${instance}.service" fusion.service > "$artifact_dir/systemd-status.txt" 2>&1 || true
  journalctl --user-unit "vllm@${instance}.service" -n 500 --no-pager -o short-iso > "$artifact_dir/journal-vllm.txt" 2>&1 || true
  journalctl --user-unit fusion.service -n 300 --no-pager -o short-iso > "$artifact_dir/journal-fusion.txt" 2>&1 || true
  nvidia-smi > "$artifact_dir/nvidia-smi.txt" 2>&1 || true
  ps -eo pid,ppid,stat,pcpu,pmem,rss,vsz,args | grep -E 'vllm|fusion|tmux' | grep -v grep > "$artifact_dir/processes.txt" 2>&1 || true
  printf '%s\n' "$runtime" > "$artifact_dir/vllm-runtime-path.txt"
  [ ! -r "$HOME/.cache/vllm-${instance}/runtime_command.sh" ] || cp "$HOME/.cache/vllm-${instance}/runtime_command.sh" "$artifact_dir/runtime_command.sh"
  redact_file "$benchmark_env" "$artifact_dir/benchmark.env"
  redact_file "$instance_env" "$artifact_dir/model.env"
}

finish_archive() {
  local status="$1"
  echo "$status" > "$artifact_dir/status.txt"
  capture_metadata
  tar -C "$artifact_root" -czf "$archive" "$(basename "$artifact_dir")"
  echo
  echo "Benchmark artifact: $archive"
}

run_case() {
  local name="$1"
  local slug="$2"
  local num_prompts="$3"
  local input_len="$4"
  local output_len="$5"
  local log_file="$artifact_dir/${slug}.log"

  echo
  echo "=== $name ==="
  echo "served_model=$MODEL tokenizer=$TOKENIZER base_url=$BASE_URL prompts=$num_prompts concurrency=2 input=$input_len output=$output_len"
  set +e
  "$runtime/bin/vllm" bench serve \
    --backend openai-chat \
    --base-url "$BASE_URL" \
    --endpoint /v1/chat/completions \
    --dataset-name random \
    --model "$MODEL" \
    --tokenizer "$TOKENIZER" \
    --num-prompts "$num_prompts" \
    --max-concurrency 2 \
    --random-input-len "$input_len" \
    --random-output-len "$output_len" \
    --temperature 0 \
    "${auth_args[@]}" 2>&1 | tee "$log_file"
  rc="${PIPESTATUS[0]}"
  set -e
  echo "$rc" > "$artifact_dir/${slug}.exit-code"
  if [ "$rc" -eq 0 ]; then
    write_summary "$name" "$slug"
  fi
  return "$rc"
}

benchmark_env="$(find_benchmark_env)"
load_env_key "$benchmark_env" BASE_URL
load_env_key "$benchmark_env" MODEL
load_env_key "$benchmark_env" VLLM_API_KEY

instance="$(basename "$(dirname "$benchmark_env")")"
instance="${instance#vllm-}"
instance_env="$HOME/.config/vllm/${instance}.env"
if [ -r "$instance_env" ]; then
  load_env_key "$instance_env" TOKENIZER
  if [ -z "${TOKENIZER:-}" ]; then
    load_env_key "$instance_env" MODEL
    TOKENIZER="$MODEL"
    load_env_key "$benchmark_env" MODEL
  fi
fi

BASE_URL="${BASE_URL:-http://127.0.0.1:8000}"
BASE_URL="${BASE_URL%/}"
BASE_URL="${BASE_URL%/v1}"
MODEL="${MODEL:-}"
TOKENIZER="${TOKENIZER:-$MODEL}"
if [ -z "$MODEL" ]; then
  echo "MODEL missing from $benchmark_env" >&2
  exit 1
fi
if [ -z "$TOKENIZER" ]; then
  echo "TOKENIZER missing; expected MODEL in $instance_env" >&2
  exit 1
fi

SMALL_PROMPTS="${SMALL_PROMPTS:-4}"
SMALL_INPUT_LEN="${SMALL_INPUT_LEN:-1024}"
SMALL_OUTPUT_LEN="${SMALL_OUTPUT_LEN:-32}"
MEDIUM_PROMPTS="${MEDIUM_PROMPTS:-4}"
MEDIUM_INPUT_LEN="${MEDIUM_INPUT_LEN:-4096}"
MEDIUM_OUTPUT_LEN="${MEDIUM_OUTPUT_LEN:-64}"
LONG_PROMPTS="${LONG_PROMPTS:-2}"
LONG_INPUT_LEN="${LONG_INPUT_LEN:-48000}"
LONG_OUTPUT_LEN="${LONG_OUTPUT_LEN:-64}"

auth_args=()
if [ -n "${VLLM_API_KEY:-}" ]; then
  auth_args+=(--header "Authorization=Bearer $VLLM_API_KEY")
fi

nix_bin="$(find_nix)"
VLLM_NIX_CONFIG="${VLLM_NIX_CONFIG:-$HOME/.config/nix/vllm-runtime.nix}"
runtime="$($nix_bin --extra-experimental-features "nix-command flakes" build --no-link --print-out-paths --file "$VLLM_NIX_CONFIG")"

if ! "$runtime/bin/vllm" bench serve --help >/dev/null 2>&1; then
  echo "Pinned vLLM runtime does not expose: vllm bench serve" >&2
  exit 1
fi

timestamp="$(date +%Y%m%d-%H%M%S)"
artifact_root="$HOME/.cache/vllm-benchmarks"
artifact_dir="$artifact_root/${timestamp}-${instance}"
archive="$artifact_dir.tar.gz"
mkdir -p "$artifact_dir"
trap 'finish_archive interrupted; exit 130' INT TERM

redact_file "$benchmark_env" "$artifact_dir/benchmark.env"
redact_file "$instance_env" "$artifact_dir/model.env"

echo "Using benchmark env: $benchmark_env"
echo "Using vLLM runtime: $runtime"
echo "Benchmark artifact directory: $artifact_dir"

status=success
run_case "Small requests" "small-requests" "$SMALL_PROMPTS" "$SMALL_INPUT_LEN" "$SMALL_OUTPUT_LEN" || status=failed
if [ "$status" = success ]; then
  run_case "Medium requests" "medium-requests" "$MEDIUM_PROMPTS" "$MEDIUM_INPUT_LEN" "$MEDIUM_OUTPUT_LEN" || status=failed
fi
if [ "$status" = success ]; then
  run_case "Long-context requests" "long-context-requests" "$LONG_PROMPTS" "$LONG_INPUT_LEN" "$LONG_OUTPUT_LEN" || status=failed
fi

finish_archive "$status"
[ "$status" = success ]
