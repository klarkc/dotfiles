#!/usr/bin/env bash
set -euo pipefail

src_root="${HOME}/Sources/Fusion"
dst_root="${HOME}/.fusion-backup/projects"

if [ ! -d "$src_root" ]; then
  echo "Fusion source root not found: $src_root" >&2
  exit 0
fi

mkdir -p "$dst_root"

find "$src_root" -mindepth 2 -maxdepth 2 -type d -print0 |
while IFS= read -r -d '' project_dir; do
  project_name="${project_dir#"$src_root"/}"
  target_dir="$dst_root/$project_name"

  copied=false
  mkdir -p "$target_dir"

  if [ -d "$project_dir/.fusion" ]; then
    mkdir -p "$target_dir/.fusion"
    rsync -a "$project_dir/.fusion/" "$target_dir/.fusion/"
    copied=true
  fi

  if [ -d "$project_dir/.worktrees" ]; then
    mkdir -p "$target_dir/.worktrees"
    rsync -a --delete "$project_dir/.worktrees/" "$target_dir/.worktrees/"
    copied=true
  fi

  if [ "$copied" = false ]; then
    rmdir "$target_dir" 2>/dev/null || true
  fi
done
