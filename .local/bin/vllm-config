#!/usr/bin/env bash
set -euo pipefail

choices=(
  "qwen3.6-35B-a3b:Qwen3.6 35B A3B"
  "qwen3.6-27B:Qwen3.6 27B MTP"
)

usage() {
  cat <<'EOF'
Usage: vllm-config [MODEL]

Models:
  qwen3.6-35B-a3b
  qwen3.6-27B

Without MODEL, shows an interactive menu.
EOF
}

pick="${1:-}"
if [ "${pick:-}" = "-h" ] || [ "${pick:-}" = "--help" ]; then
  usage
  exit 0
fi

if [ -z "$pick" ]; then
  echo "Select vLLM model to run:"
  i=1
  for item in "${choices[@]}"; do
    key="${item%%:*}"
    label="${item#*:}"
    printf '  %s) %s (%s)\n' "$i" "$label" "$key"
    i=$((i + 1))
  done
  printf 'Choice: '
  read -r answer
  case "$answer" in
    1) pick="qwen3.6-35B-a3b" ;;
    2) pick="qwen3.6-27B" ;;
    *) echo "Invalid choice: $answer" >&2; exit 2 ;;
  esac
fi

case "$pick" in
  qwen3.6-35B-a3b|qwen3.6-27B) ;;
  *) echo "Unknown model: $pick" >&2; usage >&2; exit 2 ;;
esac

selected_target="vllm-${pick}.target"
all_targets=()
all_services=()
for item in "${choices[@]}"; do
  key="${item%%:*}"
  all_targets+=("vllm-${key}.target")
  all_services+=("vllm@${key}.service")
done

printf 'Stopping Fusion and vLLM units through systemd...\n'
systemctl --user stop fusion.service "${all_targets[@]}" "${all_services[@]}" 2>/dev/null || true

printf 'Starting selected target: %s\n' "$selected_target"
systemctl --user daemon-reload
systemctl --user reset-failed fusion.service "$selected_target" "${all_services[@]}" 2>/dev/null || true
systemctl --user start "$selected_target"

echo
systemctl --user --no-pager -l status "$selected_target" fusion.service || true
cat <<EOF

Systemd owns the orchestration. The selected target starts one vLLM service and Fusion.
Watch progress with:
  journalctl --user-unit $selected_target -f
  journalctl --user-unit vllm@${pick}.service -f
  journalctl --user-unit fusion.service -f
EOF
