#!/usr/bin/env bash
set -euo pipefail

choices=(
  "qwen3.6-35B-a3b:Qwen3.6 35B A3B"
  "qwen3.6-27B:Qwen3.6 27B"
)

usage() {
  cat <<'EOF'
Usage: vllm-config [MODEL]

Models:
  qwen3.6-35B-a3b
  qwen3.6-27B

Without MODEL, shows an interactive menu.
EOF
}

pick="${1:-}"
if [ "${pick:-}" = "-h" ] || [ "${pick:-}" = "--help" ]; then
  usage
  exit 0
fi

if [ -z "$pick" ]; then
  echo "Select vLLM model to run:"
  i=1
  for item in "${choices[@]}"; do
    key="${item%%:*}"
    label="${item#*:}"
    printf '  %s) %s (%s)\n' "$i" "$label" "$key"
    i=$((i + 1))
  done
  printf 'Choice: '
  read -r answer
  case "$answer" in
    1) pick="qwen3.6-35B-a3b" ;;
    2) pick="qwen3.6-27B" ;;
    *) echo "Invalid choice: $answer" >&2; exit 2 ;;
  esac
fi

case "$pick" in
  qwen3.6-35B-a3b|qwen3.6-27B) ;;
  *) echo "Unknown model: $pick" >&2; usage >&2; exit 2 ;;
esac

selected_target="vllm-${pick}.target"
selected_service="vllm@${pick}.service"
fusion_service="fusion.service"
all_targets=()
all_services=()
other_targets=()
for item in "${choices[@]}"; do
  key="${item%%:*}"
  target="vllm-${key}.target"
  service="vllm@${key}.service"
  all_targets+=("$target")
  all_services+=("$service")
  if [ "$target" != "$selected_target" ]; then
    other_targets+=("$target")
  fi
done

unit_state() {
  systemctl --user show "$1" --property="$2" --value 2>/dev/null || true
}

since="$(date --iso-8601=seconds)"
printf 'Stopping Fusion and vLLM units through systemd...\n'
systemctl --user stop "$fusion_service" "${all_targets[@]}" "${all_services[@]}" 2>/dev/null || true

printf 'Persisting selected target: %s\n' "$selected_target"
systemctl --user daemon-reload
if [ "${#other_targets[@]}" -gt 0 ]; then
  systemctl --user disable "${other_targets[@]}" 2>/dev/null || true
fi
systemctl --user enable "$selected_target"

printf 'Starting selected target: %s\n' "$selected_target"
systemctl --user reset-failed "$fusion_service" "$selected_target" "$selected_service" "${all_services[@]}" 2>/dev/null || true
systemctl --user start --no-block "$selected_target"

echo
systemctl --user --no-pager -l status "$selected_target" "$selected_service" "$fusion_service" || true

cat <<EOF

--- Current logs since $since: $selected_service + $fusion_service ---
EOF
journalctl --user-unit "$selected_service" --user-unit "$fusion_service" --since "$since" -n 40 --no-pager -o short-iso || true

cat <<EOF

--- Following new logs: $selected_service + $fusion_service ---
EOF
journalctl --user-unit "$selected_service" --user-unit "$fusion_service" --since "$since" -n 0 -f -o short-iso &
journal_pid=$!

while kill -0 "$journal_pid" 2>/dev/null; do
  service_state="$(unit_state "$selected_service" ActiveState)"
  service_result="$(unit_state "$selected_service" Result)"
  fusion_state="$(unit_state "$fusion_service" ActiveState)"
  fusion_result="$(unit_state "$fusion_service" Result)"
  target_state="$(unit_state "$selected_target" ActiveState)"
  target_result="$(unit_state "$selected_target" Result)"

  if [ "$service_state" = active ] && [ "$fusion_state" = active ] \
    && { [ -z "$service_result" ] || [ "$service_result" = success ]; } \
    && { [ -z "$fusion_result" ] || [ "$fusion_result" = success ]; }; then
    kill "$journal_pid" 2>/dev/null || true
    wait "$journal_pid" 2>/dev/null || true
    echo
    echo "$selected_service and $fusion_service are active. Systemd will continue managing them."
    systemctl --user --no-pager -l status "$selected_service" "$fusion_service" || true
    exit 0
  fi

  if [ "$service_state" = failed ] || { [ -n "$service_result" ] && [ "$service_result" != success ]; }; then
    kill "$journal_pid" 2>/dev/null || true
    wait "$journal_pid" 2>/dev/null || true
    echo
    echo "$selected_service failed: state=${service_state:-unknown} result=${service_result:-unknown}" >&2
    systemctl --user --no-pager -l status "$selected_service" "$fusion_service" >&2 || true
    exit 1
  fi

  if [ "$fusion_state" = failed ] || { [ -n "$fusion_result" ] && [ "$fusion_result" != success ]; }; then
    kill "$journal_pid" 2>/dev/null || true
    wait "$journal_pid" 2>/dev/null || true
    echo
    echo "$fusion_service failed: state=${fusion_state:-unknown} result=${fusion_result:-unknown}" >&2
    systemctl --user --no-pager -l status "$selected_service" "$fusion_service" >&2 || true
    exit 1
  fi

  if [ "$target_state" = failed ] || { [ -n "$target_result" ] && [ "$target_result" != success ]; }; then
    kill "$journal_pid" 2>/dev/null || true
    wait "$journal_pid" 2>/dev/null || true
    echo
    echo "$selected_target failed: state=${target_state:-unknown} result=${target_result:-unknown}" >&2
    systemctl --user --no-pager -l status "$selected_target" "$selected_service" "$fusion_service" >&2 || true
    exit 1
  fi

  sleep 2
done
wait "$journal_pid"
