#!/usr/bin/env bash
set -euo pipefail

choices=(
  "qwen3.6-35B-a3b:Qwen3.6 35B A3B"
  "qwen3.6-27B:Qwen3.6 27B"
)

usage() {
  cat <<'EOF'
Usage: vllm-config [MODEL]

Models:
  qwen3.6-35B-a3b
  qwen3.6-27B

Without MODEL, shows an interactive menu.
EOF
}

pick="${1:-}"
if [ "${pick:-}" = "-h" ] || [ "${pick:-}" = "--help" ]; then
  usage
  exit 0
fi

if [ -z "$pick" ]; then
  echo "Select vLLM model to run:"
  i=1
  for item in "${choices[@]}"; do
    key="${item%%:*}"
    label="${item#*:}"
    printf '  %s) %s (%s)\n' "$i" "$label" "$key"
    i=$((i + 1))
  done
  printf 'Choice: '
  read -r answer
  case "$answer" in
    1) pick="qwen3.6-35B-a3b" ;;
    2) pick="qwen3.6-27B" ;;
    *) echo "Invalid choice: $answer" >&2; exit 2 ;;
  esac
fi

case "$pick" in
  qwen3.6-35B-a3b|qwen3.6-27B) ;;
  *) echo "Unknown model: $pick" >&2; usage >&2; exit 2 ;;
esac

selected_target="vllm-${pick}.target"
selected_service="vllm@${pick}.service"
all_targets=()
all_services=()
for item in "${choices[@]}"; do
  key="${item%%:*}"
  all_targets+=("vllm-${key}.target")
  all_services+=("vllm@${key}.service")
done

since="$(date --iso-8601=seconds)"
printf 'Stopping Fusion and vLLM units through systemd...\n'
systemctl --user stop fusion.service "${all_targets[@]}" "${all_services[@]}" 2>/dev/null || true

printf 'Starting selected target: %s\n' "$selected_target"
systemctl --user daemon-reload
systemctl --user reset-failed fusion.service "$selected_target" "$selected_service" "${all_services[@]}" 2>/dev/null || true
systemctl --user start --no-block "$selected_target"

echo
systemctl --user --no-pager -l status "$selected_target" "$selected_service" fusion.service || true

cat <<EOF

--- Current logs since $since: $selected_service + fusion.service ---
EOF
journalctl --user-unit "$selected_service" --user-unit fusion.service --since "$since" -n 40 --no-pager -o short-iso || true

cat <<EOF

--- Following new logs: $selected_service + fusion.service ---
EOF
journalctl --user-unit "$selected_service" --user-unit fusion.service --since "$since" -n 0 -f -o short-iso &
journal_pid=$!

while kill -0 "$journal_pid" 2>/dev/null; do
  service_state="$(systemctl --user show "$selected_service" --property=ActiveState --value 2>/dev/null || true)"
  service_result="$(systemctl --user show "$selected_service" --property=Result --value 2>/dev/null || true)"
  target_state="$(systemctl --user show "$selected_target" --property=ActiveState --value 2>/dev/null || true)"
  target_result="$(systemctl --user show "$selected_target" --property=Result --value 2>/dev/null || true)"

  if [ "$service_state" = failed ] || { [ -n "$service_result" ] && [ "$service_result" != success ]; }; then
    kill "$journal_pid" 2>/dev/null || true
    wait "$journal_pid" 2>/dev/null || true
    echo
    echo "$selected_service failed: state=${service_state:-unknown} result=${service_result:-unknown}" >&2
    systemctl --user --no-pager -l status "$selected_service" fusion.service >&2 || true
    exit 1
  fi

  if [ "$target_state" = failed ] || { [ -n "$target_result" ] && [ "$target_result" != success ]; }; then
    kill "$journal_pid" 2>/dev/null || true
    wait "$journal_pid" 2>/dev/null || true
    echo
    echo "$selected_target failed: state=${target_state:-unknown} result=${target_result:-unknown}" >&2
    systemctl --user --no-pager -l status "$selected_target" "$selected_service" fusion.service >&2 || true
    exit 1
  fi

  sleep 2
done
wait "$journal_pid"
