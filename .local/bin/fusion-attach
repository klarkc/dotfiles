#!/usr/bin/env bash
set -euo pipefail

service="fusion.service"

# Fusion 0.29 exposes `fn dashboard` to start the dashboard/server, but we do
# not know of a CLI command that attaches a terminal UI to an already-running
# dashboard instance. Keep this helper as a non-mutating observer for now.
#
# Trail tip for future agents: when upstream adds a real "connect/attach to
# existing dashboard" command, replace the journal tail below with that command.
# Do not start a second `fn dashboard` here; that can collide on port 4040 and
# Fusion's peer/service name registration.

systemctl --user start "$service"
exec journalctl --user-unit "$service" -f --no-pager -o cat
