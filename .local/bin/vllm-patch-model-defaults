#!/usr/bin/env bash
set -euo pipefail

model_id="${SERVED_MODEL_NAME:?SERVED_MODEL_NAME is required}"
model_name="${DISPLAY_MODEL_NAME:-$model_id}"
raw_context_window="${MAX_MODEL_LEN:-49152}"
max_tokens="${DEFAULT_MAX_TOKENS:-4096}"
max_num_seqs="${MAX_NUM_SEQS:-2}"
port="${PORT:-8000}"
base_url="http://localhost:${port}/v1/"
client_context_window="$(( raw_context_window - ((max_tokens * 3) / 2) ))"
if [ "$client_context_window" -lt 1024 ]; then
  client_context_window=1024
fi

mkdir -p "$HOME/.fusion" "$HOME/.pi/agent"
cat > "$HOME/.fusion/vllm-defaults.env" <<EOF
VLLM_BASE_URL=$base_url
VLLM_MODEL=$model_id
VLLM_MODEL_NAME=$model_name
VLLM_RAW_CONTEXT_WINDOW=$raw_context_window
VLLM_CONTEXT_WINDOW=$client_context_window
VLLM_MAX_TOKENS=$max_tokens
VLLM_MAX_NUM_SEQS=$max_num_seqs
EOF

fusion_settings="$HOME/.fusion/settings.json"
if [ -f "$fusion_settings" ]; then
  python3 - "$fusion_settings" "$model_id" "$base_url" <<'PY'
import json
import os
import sys

path, model_id, base_url = sys.argv[1:]
models = [
    {'id': 'qwen3.6-35b-a3b', 'name': 'Qwen3.6 35B A3B'},
    {'id': 'qwen3.6-27b', 'name': 'Qwen3.6 27B'},
]
with open(path, 'r', encoding='utf-8') as f:
    data = json.load(f)
if not isinstance(data, dict):
    raise SystemExit(f'{path} must contain a JSON object')
providers = data.setdefault('customProviders', [])
if not isinstance(providers, list):
    providers = []
    data['customProviders'] = providers
provider = None
for item in providers:
    if isinstance(item, dict) and item.get('id') == 'vllm':
        provider = item
        break
if provider is None:
    provider = {'id': 'vllm'}
    providers.append(provider)
provider['name'] = 'vLLM'
provider['apiType'] = 'openai-compatible'
provider['baseUrl'] = base_url
provider['models'] = models
data['defaultProvider'] = 'vllm'
data['defaultModelId'] = model_id
data['fallbackProvider'] = 'vllm'
data['fallbackModelId'] = model_id
tmp = path + '.tmp'
with open(tmp, 'w', encoding='utf-8') as f:
    json.dump(data, f, indent=2)
    f.write('\n')
os.replace(tmp, path)
PY
fi

crush_config="$HOME/.config/crush/crush.json"
if [ -f "$crush_config" ]; then
  python3 - "$crush_config" "$client_context_window" "$max_tokens" "$base_url" <<'PY'
import json
import os
import sys

path, context_window, max_tokens, base_url = sys.argv[1:]
models = [
    {
        'name': 'Qwen3.6 35B A3B',
        'id': 'qwen3.6-35b-a3b',
        'context_window': int(context_window),
        'default_max_tokens': int(max_tokens),
        'cost_per_1m_in': 0,
        'cost_per_1m_out': 0,
    },
    {
        'name': 'Qwen3.6 27B',
        'id': 'qwen3.6-27b',
        'context_window': int(context_window),
        'default_max_tokens': int(max_tokens),
        'cost_per_1m_in': 0,
        'cost_per_1m_out': 0,
    },
]
with open(path, 'r', encoding='utf-8') as f:
    data = json.load(f)
vllm = data.setdefault('providers', {}).setdefault('vllm', {})
vllm['name'] = 'vLLM'
vllm['base_url'] = base_url
vllm['api_key'] = '$' + 'VLLM_API_KEY'
vllm['type'] = 'openai-compat'
vllm['models'] = models
tmp = path + '.tmp'
with open(tmp, 'w', encoding='utf-8') as f:
    json.dump(data, f, indent=2)
    f.write('\n')
os.replace(tmp, path)
PY
fi

pi_models="$HOME/.pi/agent/models.json"
if [ -f "$pi_models" ]; then
  python3 - "$pi_models" "$client_context_window" "$max_tokens" "$max_num_seqs" <<'PY'
import json
import os
import sys

path, context_window, max_tokens, max_num_seqs = sys.argv[1:]
context_window = int(context_window)
max_tokens = int(max_tokens)
max_num_seqs = int(max_num_seqs)
model_ids = {'qwen3.6-35b-a3b', 'qwen3.6-27b'}
with open(path, 'r', encoding='utf-8') as f:
    data = json.load(f)

def is_model_entry(obj):
    if not isinstance(obj, dict):
        return False
    return any(obj.get(field) in model_ids for field in ('id', 'model', 'modelId'))

def patch(obj):
    if isinstance(obj, dict):
        if is_model_entry(obj):
            for key in ('contextWindow', 'context_window', 'maxContextTokens', 'max_context_tokens'):
                if key in obj:
                    obj[key] = context_window
            for key in ('maxTokens', 'max_tokens', 'defaultMaxTokens', 'default_max_tokens'):
                if key in obj:
                    obj[key] = max_tokens
            for key in ('maxConcurrent', 'max_concurrent', 'parallelRequests', 'parallel_requests'):
                if key in obj:
                    obj[key] = max_num_seqs
        for value in obj.values():
            patch(value)
    elif isinstance(obj, list):
        for value in obj:
            patch(value)

patch(data)
tmp = path + '.tmp'
with open(tmp, 'w', encoding='utf-8') as f:
    json.dump(data, f, indent=2)
    f.write('\n')
os.replace(tmp, path)
PY
fi

echo "Selected vLLM model defaults: $model_id, raw_context=$raw_context_window, client_context=$client_context_window, max_tokens=$max_tokens, max_num_seqs=$max_num_seqs"