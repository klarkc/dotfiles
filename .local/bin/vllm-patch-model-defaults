#!/usr/bin/env bash
set -euo pipefail

model_id="${SERVED_MODEL_NAME:?SERVED_MODEL_NAME is required}"
model_name="${DISPLAY_MODEL_NAME:-$model_id}"
raw_context_window="${MAX_MODEL_LEN:-49152}"
max_tokens="${DEFAULT_MAX_TOKENS:-4096}"
max_num_seqs="${MAX_NUM_SEQS:-2}"
port="${PORT:-8000}"
base_url="http://localhost:${port}/v1"
client_context_window="$(( raw_context_window - ((max_tokens * 3) / 2) ))"
if [ "$client_context_window" -lt 1024 ]; then
  client_context_window=1024
fi

mkdir -p "$HOME/.fusion/agent" "$HOME/.pi/agent"
cat > "$HOME/.fusion/vllm-defaults.env" <<EOF
VLLM_BASE_URL=$base_url
VLLM_MODEL=$model_id
VLLM_MODEL_NAME=$model_name
VLLM_RAW_CONTEXT_WINDOW=$raw_context_window
VLLM_CONTEXT_WINDOW=$client_context_window
VLLM_MAX_TOKENS=$max_tokens
VLLM_MAX_NUM_SEQS=$max_num_seqs
EOF

fusion_settings="$HOME/.fusion/settings.json"
if [ -f "$fusion_settings" ]; then
  python3 - "$fusion_settings" "$model_id" <<'PY'
import json
import os
import sys

path, model_id = sys.argv[1:]
with open(path, 'r', encoding='utf-8') as f:
    data = json.load(f)
if not isinstance(data, dict):
    raise SystemExit(f'{path} must contain a JSON object')
data['defaultProvider'] = 'local-vllm'
data['defaultModelId'] = model_id
data['fallbackProvider'] = 'local-vllm'
data['fallbackModelId'] = model_id
data['customProviders'] = []
tmp = path + '.tmp'
with open(tmp, 'w', encoding='utf-8') as f:
    json.dump(data, f, indent=2)
    f.write('\n')
os.replace(tmp, path)
PY
fi

fusion_auth="$HOME/.fusion/agent/auth.json"
python3 - "$fusion_auth" <<'PY'
import json
import os
import sys

path = sys.argv[1]
try:
    with open(path, 'r', encoding='utf-8') as f:
        data = json.load(f)
except FileNotFoundError:
    data = {}
if not isinstance(data, dict):
    data = {}
data['local-vllm'] = {'type': 'api_key', 'key': 'VLLM_API_KEY'}
os.makedirs(os.path.dirname(path), exist_ok=True)
tmp = path + '.tmp'
with open(tmp, 'w', encoding='utf-8') as f:
    json.dump(data, f, indent=2)
    f.write('\n')
os.replace(tmp, path)
PY

pi_models="$HOME/.pi/agent/models.json"
python3 - "$pi_models" "$client_context_window" "$max_tokens" "$max_num_seqs" "$base_url" <<'PY'
import json
import os
import sys

path, context_window, max_tokens, max_num_seqs, base_url = sys.argv[1:]
context_window = int(context_window)
max_tokens = int(max_tokens)
models = [
    {
        'id': 'qwen3.6-35b-a3b',
        'name': 'Qwen3.6 35B A3B',
        'reasoning': True,
        'input': ['text'],
        'contextWindow': context_window,
        'maxTokens': max_tokens,
        'cost': {'input': 0, 'output': 0, 'cacheRead': 0, 'cacheWrite': 0},
    },
    {
        'id': 'qwen3.6-27b',
        'name': 'Qwen3.6 27B',
        'reasoning': True,
        'input': ['text'],
        'contextWindow': context_window,
        'maxTokens': max_tokens,
        'cost': {'input': 0, 'output': 0, 'cacheRead': 0, 'cacheWrite': 0},
    },
]
provider = {
    'name': 'local-vllm',
    'baseUrl': base_url,
    'api': 'openai-completions',
    'apiKey': 'VLLM_API_KEY',
    'compat': {
        'supportsDeveloperRole': False,
        'supportsReasoningEffort': False,
        'maxTokensField': 'max_tokens',
    },
    'models': models,
}
try:
    with open(path, 'r', encoding='utf-8') as f:
        data = json.load(f)
except FileNotFoundError:
    data = {}
if not isinstance(data, dict):
    data = {}
providers = data.get('providers')
if not isinstance(providers, dict):
    providers = {}
providers['local-vllm'] = provider
data['providers'] = providers
os.makedirs(os.path.dirname(path), exist_ok=True)
tmp = path + '.tmp'
with open(tmp, 'w', encoding='utf-8') as f:
    json.dump(data, f, indent=2)
    f.write('\n')
os.replace(tmp, path)
PY

opencode_config="$HOME/.config/opencode/opencode.json"
if [ -f "$opencode_config" ]; then
  python3 - "$opencode_config" "$base_url" "$client_context_window" "$max_tokens" "$model_id" "$model_name" <<'PY'
import json
import os
import sys

path, base_url, context_window, max_tokens, model_id, model_name = sys.argv[1:]
with open(path, 'r', encoding='utf-8') as f:
    data = json.load(f)
if not isinstance(data, dict):
    raise SystemExit(f'{path} must contain a JSON object')
try:
    data['provider']['vllm']['options']['baseURL'] = base_url
except (KeyError, TypeError):
    data.setdefault('provider', {})['vllm'] = {'options': {}}
    data['provider']['vllm']['options']['baseURL'] = base_url
models = data['provider']['vllm'].setdefault('models', {})
current_id = models.get(model_id, {})
if isinstance(current_id, dict):
    current_id['name'] = model_name
    current_id['limit']['context'] = int(context_window)
    current_id['limit']['output'] = int(max_tokens)
else:
    models[model_id] = {'name': model_name, 'limit': {'context': int(context_window), 'output': int(max_tokens)}}
tmp = path + '.tmp'
with open(tmp, 'w', encoding='utf-8') as f:
    json.dump(data, f, indent=2)
    f.write('\n')
os.replace(tmp, path)
PY
fi

crush_config="$HOME/.config/crush/crush.json"
if [ -f "$crush_config" ]; then
  python3 - "$crush_config" "$client_context_window" "$max_tokens" "$base_url/" <<'PY'
import json
import os
import sys

path, context_window, max_tokens, base_url = sys.argv[1:]
models = [
    {
        'name': 'Qwen3.6 35B A3B',
        'id': 'qwen3.6-35b-a3b',
        'context_window': int(context_window),
        'default_max_tokens': int(max_tokens),
        'cost_per_1m_in': 0,
        'cost_per_1m_out': 0,
    },
    {
        'name': 'Qwen3.6 27B',
        'id': 'qwen3.6-27b',
        'context_window': int(context_window),
        'default_max_tokens': int(max_tokens),
        'cost_per_1m_in': 0,
        'cost_per_1m_out': 0,
    },
]
with open(path, 'r', encoding='utf-8') as f:
    data = json.load(f)
vllm = data.setdefault('providers', {}).setdefault('vllm', {})
vllm['name'] = 'vLLM'
vllm['base_url'] = base_url
vllm['api_key'] = '$' + 'VLLM_API_KEY'
vllm['type'] = 'openai-compat'
vllm['models'] = models
tmp = path + '.tmp'
with open(tmp, 'w', encoding='utf-8') as f:
    json.dump(data, f, indent=2)
    f.write('\n')
os.replace(tmp, path)
PY
fi

echo "Selected vLLM model defaults: $model_id, raw_context=$raw_context_window, client_context=$client_context_window, max_tokens=$max_tokens, max_num_seqs=$max_num_seqs"