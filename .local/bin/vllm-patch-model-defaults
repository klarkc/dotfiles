#!/usr/bin/env bash
set -euo pipefail

model_id="${SERVED_MODEL_NAME:?SERVED_MODEL_NAME is required}"
model_name="${DISPLAY_MODEL_NAME:-$model_id}"
raw_context_window="${MAX_MODEL_LEN:-49152}"
max_tokens="${DEFAULT_MAX_TOKENS:-4096}"
max_num_seqs="${MAX_NUM_SEQS:-2}"
port="${PORT:-8000}"
base_url="http://localhost:${port}/v1/"
client_context_window="$(( (raw_context_window - max_tokens) * 70 / 100 ))"
if [ "$client_context_window" -lt 1024 ]; then
  client_context_window=1024
fi

mkdir -p "$HOME/.fusion" "$HOME/.pi/agent"
cat > "$HOME/.fusion/vllm-defaults.env" <<EOF
VLLM_BASE_URL=$base_url
VLLM_MODEL=$model_id
VLLM_MODEL_NAME=$model_name
VLLM_RAW_CONTEXT_WINDOW=$raw_context_window
VLLM_CONTEXT_WINDOW=$client_context_window
VLLM_MAX_TOKENS=$max_tokens
VLLM_MAX_NUM_SEQS=$max_num_seqs
EOF

crush_config="$HOME/.config/crush/crush.json"
if [ -f "$crush_config" ]; then
  python3 - "$crush_config" "$client_context_window" "$max_tokens" "$base_url" <<'PY'
import json
import os
import sys

path, context_window, max_tokens, base_url = sys.argv[1:]
models = [
    {
        'name': 'Qwen3.6 35B A3B',
        'id': 'qwen3.6-35b-a3b',
        'context_window': int(context_window),
        'default_max_tokens': int(max_tokens),
        'cost_per_1m_in': 0,
        'cost_per_1m_out': 0,
    },
    {
        'name': 'Qwen3.6 27B',
        'id': 'qwen3.6-27b',
        'context_window': int(context_window),
        'default_max_tokens': int(max_tokens),
        'cost_per_1m_in': 0,
        'cost_per_1m_out': 0,
    },
]
with open(path, 'r', encoding='utf-8') as f:
    data = json.load(f)
vllm = data.setdefault('providers', {}).setdefault('vllm', {})
vllm['name'] = 'vLLM'
vllm['base_url'] = base_url
vllm['api_key'] = '$VLLM_API_KEY'
vllm['type'] = 'openai-compat'
vllm['models'] = models
tmp = path + '.tmp'
with open(tmp, 'w', encoding='utf-8') as f:
    json.dump(data, f, indent=2)
    f.write('\n')
os.replace(tmp, path)
PY
fi

pi_models="$HOME/.pi/agent/models.json"
if [ -f "$pi_models" ]; then
  python3 - "$pi_models" "$client_context_window" "$max_tokens" "$max_num_seqs" "$base_url" <<'PY'
import json
import os
import sys

path, context_window, max_tokens, max_num_seqs, base_url = sys.argv[1:]
model_entries = {
    'qwen3.6-35b-a3b': {
        'name': 'Qwen3.6 35B A3B',
        'id': 'qwen3.6-35b-a3b',
        'model': 'qwen3.6-35b-a3b',
        'provider': 'vllm',
        'base_url': base_url,
        'context_window': int(context_window),
        'max_context_tokens': int(context_window),
        'default_max_tokens': int(max_tokens),
        'max_tokens': int(max_tokens),
        'max_concurrent': int(max_num_seqs),
        'parallel_requests': int(max_num_seqs),
    },
    'qwen3.6-27b': {
        'name': 'Qwen3.6 27B',
        'id': 'qwen3.6-27b',
        'model': 'qwen3.6-27b',
        'provider': 'vllm',
        'base_url': base_url,
        'context_window': int(context_window),
        'max_context_tokens': int(context_window),
        'default_max_tokens': int(max_tokens),
        'max_tokens': int(max_tokens),
        'max_concurrent': int(max_num_seqs),
        'parallel_requests': int(max_num_seqs),
    },
}
try:
    with open(path, 'r', encoding='utf-8') as f:
        data = json.load(f)
except json.JSONDecodeError:
    data = {}

if isinstance(data, list):
    by_id = {}
    for item in data:
        if isinstance(item, dict):
            key = item.get('id') or item.get('model') or item.get('name')
            if key:
                by_id[key] = item
    for key, entry in model_entries.items():
        current = by_id.get(key, {})
        current.update(entry)
        by_id[key] = current
    data = list(by_id.values())
elif isinstance(data, dict):
    if isinstance(data.get('models'), list):
        by_id = {}
        for item in data['models']:
            if isinstance(item, dict):
                key = item.get('id') or item.get('model') or item.get('name')
                if key:
                    by_id[key] = item
        for key, entry in model_entries.items():
            current = by_id.get(key, {})
            current.update(entry)
            by_id[key] = current
        data['models'] = list(by_id.values())
    else:
        models = data.setdefault('models', {})
        if isinstance(models, dict):
            for key, entry in model_entries.items():
                current = models.get(key, {})
                if not isinstance(current, dict):
                    current = {}
                current.update(entry)
                models[key] = current
        else:
            data['models'] = model_entries
else:
    data = {'models': model_entries}

tmp = path + '.tmp'
with open(tmp, 'w', encoding='utf-8') as f:
    json.dump(data, f, indent=2)
    f.write('\n')
os.replace(tmp, path)
PY
fi

echo "Selected vLLM model defaults: $model_id, raw_context=$raw_context_window, client_context=$client_context_window, max_tokens=$max_tokens, max_num_seqs=$max_num_seqs"