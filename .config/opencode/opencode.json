{
	"$schema": "https://opencode.ai/config.json",
	"provider": {
		"vllm": {
			"name": "vLLM",
			"options": {
				"baseURL": "http://localhost:8000/v1",
				"apiKey": "{env:VLLM_API_KEY}"
			},
			"models": {
				"qwen3.6-35b-a3b": {
					"name": "Qwen3.6 35B A3B",
					"temperature": true,
					"reasoning": true,
					"tool_call": true,
					"interleaved": {
						"field": "reasoning"
					},

					"limit": {
						"context": 43008,
						"output": 4096
					},

					"options": {
						"top_k": 20,
						"min_p": 0.0,
						"presence_penalty": 0.0,
						"repetition_penalty": 1.1,
						"thinking_token_budget": 2048
					}
				}
			}
		}
	},
	"agent": {
		"build": {
			"temperature": 0.6,
			"top_p": 0.95,
			"steps": 50
		},
		"plan": {
			"temperature": 0.8,
			"top_p": 0.95,
			"steps": 32,
			"options": {
				"presence_penalty": 0.4,
				"repetition_penalty": 1.08,
				"thinking_token_budget": 4096
			}
		},
		"general": {
			"temperature": 0.6,
			"top_p": 0.95,
			"steps": 36
		},
		"explore": {
			"temperature": 0.35,
			"top_p": 0.9,
			"steps": 18,
			"options": {
				"thinking_token_budget": 1024
			}
		},
		"scout": {
			"temperature": 0.55,
			"top_p": 0.95,
			"steps": 24,
			"options": {
				"presence_penalty": 0.3,
				"repetition_penalty": 1.08,
				"thinking_token_budget": 1536
			}
		},
		"compaction": {
			"temperature": 0.2,
			"top_p": 0.8,
			"steps": 4,
			"options": {
				"thinking_token_budget": 512
			}
		},
		"summary": {
			"temperature": 0.2,
			"top_p": 0.8,
			"steps": 4,
			"options": {
				"thinking_token_budget": 512
			}
		},
		"title": {
			"temperature": 0.1,
			"top_p": 0.8,
			"steps": 2,
			"options": {
				"thinking_token_budget": 256
			}
		}
	},
	"permission": {
		"doom_loop": "allow",
		"external_directory": {
			"~/.cache/**": "allow",
			"~/.npm/**": "allow",
			"/tmp/**": "allow",
			"/run/user/1000/**": "allow",
			"/nix/var/**": "allow",
			"/nix/store/**": "allow"
		}
	}
}
