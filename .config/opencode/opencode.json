{
	"$schema": "https://opencode.ai/config.json",
	"provider": {
		"vllm": {
			"name": "vLLM",
			"options": {
				"baseURL": "http://localhost:8000/v1",
				"apiKey": "{env:VLLM_API_KEY}"
			},
			"models": {
				"qwen3.6-35b-a3b": {
					"name": "Qwen3.6 35B A3B",
					"temperature": true,
					"reasoning": true,
					"tool_call": true,
					"interleaved": {
						"field": "reasoning"
					},
					"limit": {
						"context": 43008,
						"output": 4096
					},
					"options": {
						"top_k": 20,
						"min_p": 0.0,
						"presence_penalty": 0.0,
						"repetition_penalty": 1.1,
						"thinking_token_budget": 2048
					}
				}
			}
		}
	},
	"agent": {
		"build": {
			"temperature": 0.6,
			"top_p": 0.95,
			"steps": 50
		},
		"plan": {
			"temperature": 1.0,
			"top_p": 0.95,
			"steps": 30,
			"options": {
				"presence_penalty": 1.0,
				"repetition_penalty": 1.05,
				"thinking_token_budget": 4096
			}
		}
	},
	"permission": {
		"doom_loop": "allow",
		"external_directory": {
			"~/.cache/**": "allow",
			"~/.npm/**": "allow",
			"/tmp/**": "allow",
			"/run/user/1000/**": "allow",
			"/nix/var/**": "allow",
			"/nix/store/**": "allow"
		}
	}
}
