	"mcp": {
		"codex": {
			"type": "stdio",
			"command": "codex",
			"args": [
				"mcp-server",
        "-c",
        "sandbox_mode=workspace-write",
        "-c",
        "shell_environment_policy.inherit=all"
			]
		}
	},
	"permissions": {
		"allowed_tools": [
      "agent",
			"agentic_fetch",
			"download",
			"fetch",
			"glob",
			"grep",
      "job_output",
      "list_mcp_resources",
			"ls",
			"lsp_diagnostics",
			"lsp_references",
			"lsp_restart",
      "read_mcp_resource",
			"sourcegraph",
			"view"
		]
	}
}
