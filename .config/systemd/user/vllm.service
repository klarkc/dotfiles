D_MODEL_NAME"; echo "VLLM_API_KEY=$$VLLM_API_KEY"; echo "PROMPTS=$${BENCHMARK_PROMPTS}"; echo "MAX_TOKENS=$${BENCHMARK_MAX_TOKENS}"; echo "CACHE=$$CACHE"; echo "VENV=$$VENV"; } > "$$CACHE/benchmark.env"; echo "Benchmark metadata: $$CACHE/benchmark.env"; echo "Runtime command: $$CACHE/runtime_command.sh"; echo "Using pinned nixpkgs rev: $$NIXPKGS_REV"; echo "Using CUDA driver source: $$LIBCUDA_SO"; echo "Using isolated driver lib dir: $$DRIVER_LINK_DIR"; echo "Using C++ runtime lib: $$CXX_RUNTIME_LIB"; echo "Using Python site-packages: $$PY_SITE"; echo "Using CUDA package lib dirs: $${CUDA_PKG_LIB_DIRS:-none}"; echo "Using torch lib dir: $${TORCH_LIB_DIR:-none}"; echo "Using uv binary: $$UV_BIN"; echo "Using uv install spec: $$UV_INSTALL_SPEC"; echo "Using vLLM install spec: $$VLLM_INSTALL_SPEC"; echo "Using PyTorch install spec: $$PYTORCH_INSTALL_SPEC"; echo "Using uv torch backend: $$UV_TORCH_BACKEND"; echo "Using uv exclude newer: $${UV_EXCLUDE_NEWER:-none}"; echo "Serving model: $$MODEL as $$SERVED_MODEL_NAME"; echo "model_revision=$${MODEL_REVISION:-unPinned}"; echo "host=$$HOST port=$$PORT max_model_len=$$MAX_MODEL_LEN max_num_seqs=$$MAX_NUM_SEQS max_num_batched_tokens=$$MAX_NUM_BATCHED_TOKENS"; echo "gpu_memory_utilization=$$GPU_MEMORY_UTILIZATION cpu_offload_gb=$$CPU_OFFLOAD_GB kv_offloading_size_gb=$$KV_OFFLOADING_SIZE_GB renderer_num_workers=$$RENDERER_NUM_WORKERS mm_processor_cache_gb=$$MM_PROCESSOR_CACHE_GB stream_interval=$$STREAM_INTERVAL marlin_atomic_add=$${VLLM_MARLIN_USE_ATOMIC_ADD:-unset}"; echo "speculative_config: $${SPECULATIVE_CONFIG:-b64:$${SPECULATIVE_CONFIG_B64:+enabled}}"; echo "extra args: $${VLLM_EXTRA_ARGS:-none}"; unset VLLM_INSTALL_SPEC VLLM_EXTRA_ARGS VLLM_SLEEP_WHEN_IDLE VLLM_USE_V1; exec "$$VENV/bin/vllm" serve "$$MODEL" "$${RUNTIME_ARGS[@]}"'

