C}"; CUDA_SOURCE_DIR=""; LIBCUDA_SO=""; for d in /run/opengl-driver/lib /run/nvidia-driver/lib /usr/lib/x86_64-linux-gnu/nvidia/current /usr/lib/x86_64-linux-gnu /usr/lib64 /usr/lib /usr/lib/nvidia; do if [ -e "$$d/libcuda.so.1" ]; then CUDA_SOURCE_DIR="$$d"; LIBCUDA_SO="$$d/libcuda.so.1"; break; fi; done; if [ -z "$$LIBCUDA_SO" ]; then LIBCUDA_SO="$$(find /run /usr/lib /usr/lib64 -maxdepth 6 -name libcuda.so.1 2>/dev/null | head -n 1 || true)"; if [ -n "$$LIBCUDA_SO" ]; then CUDA_SOURCE_DIR="$$(dirname "$$LIBCUDA_SO")"; fi; fi; if [ -z "$$LIBCUDA_SO" ] || [ ! -e "$$LIBCUDA_SO" ]; then echo "ERROR: libcuda.so.1 not found in common driver paths"; find /run /usr/lib /usr/lib64 -maxdepth 6 -name libcuda.so.1 2>/dev/null | head -50 || true; exit 1; fi; rm -rf "$$DRIVER_LINK_DIR"; mkdir -p "$$DRIVER_LINK_DIR"; for f in "$$CUDA_SOURCE_DIR"/libcuda.so* "$$CUDA_SOURCE_DIR"/libnvidia-*.so*; do [ -e "$$f" ] || continue; ln -sfn "$$(readlink -f "$$f")" "$$DRIVER_LINK_DIR/$$(basename "$$f")"; done; if [ ! -e "$$DRIVER_LINK_DIR/libcuda.so.1" ]; then ln -sfn "$$(readlink -f "$$LIBCUDA_SO")" "$$DRIVER_LINK_DIR/libcuda.so.1"; fi; if [ ! -e "$$DRIVER_LINK_DIR/libcuda.so" ]; then ln -sfn libcuda.so.1 "$$DRIVER_LINK_DIR/libcuda.so"; fi; CXX_RUNTIME_LIB="$$(g++ -print-file-name=libstdc++.so.6 2>/dev/null || true)"; if [ -z "$$CXX_RUNTIME_LIB" ] || [ ! -e "$$CXX_RUNTIME_LIB" ]; then CXX_RUNTIME_LIB="$$(find /nix/store -maxdepth 5 -path '\''*/lib/libstdc++.so.6'\'' 2>/dev/null | head -n 1 || true)"; fi; if [ -z "$$CXX_RUNTIME_LIB" ] || [ ! -e "$$CXX_RUNTIME_LIB" ]; then echo "ERROR: libstdc++.so.6 not found from pinned Nix gcc runtime"; exit 1; fi; CXX_RUNTIME_DIR="$$(dirname "$$(readlink -f "$$CXX_RUNTIME_LIB")")"; export HF_HOME="$${HF_HOME:-$$HOME/.cache/huggingface}"; export UV_LINK_MODE=copy; export UV_TORCH_BACKEND="$${UV_TORCH_BACKEND:-cu130}"; export UV_EXCLUDE_NEWER="$${UV_EXCLUDE_NEWER:-2026-05-08T23:59:59Z}"; export VLLM_USE_V1=1; export VLLM_SLEEP_WHEN_IDLE=1; export CUDA_MODULE_LOADING="$${CUDA_MODULE_LOADING:-LAZY}"; export VLLM_MARLIN_USE_ATOMIC_ADD="$${VLLM_MARLIN_USE_ATOMIC_ADD:-1}"; export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True; export OMP_NUM_THREADS="$${OMP_NUM_THREADS:-8}"; export MKL_NUM_THREADS="$${MKL_NUM_THREADS:-8}"; export OPENBLAS_NUM_THREADS="$${OPENBLAS_NUM_THREADS:-8}"; export NUMEXPR_NUM_THREADS="$${NUMEXPR_NUM_THREADS:-8}"; export RAYON_NUM_THREADS="$${RAYON_NUM_THREADS:-8}"; export TOKENIZERS_PARALLELISM="$${TOKENIZERS_PARALLELISM:-true}"; export MALLOC_ARENA_MAX="$${MALLOC_ARENA_MAX:-2}"; UV_BOOTSTRAP_FINGERPRINT="$$UV_INSTALL_SPEC|bootstrap-tools=$$PYTHON_BOOTSTRAP_TOOLS_SPEC|nixpkgs=$$NIXPKGS_REV"; if [ ! -x "$$UV_BOOTSTRAP_VENV/bin/uv" ] || [ ! -f "$$UV_SPEC_FILE" ] || [ "$$(cat "$$UV_SPEC_FILE" 2>/dev/null || true)" != "$$UV_BOOTSTRAP_FINGERPRINT" ]; then echo "Creating/rebuilding pinned uv environment at $$UV_BOOTSTRAP_VENV"; rm -rf "$$UV_BOOTSTRAP_VENV"; "$${CLEAN_ENV[@]}" virtualenv --python python3.12 "$$UV_BOOTSTRAP_VENV"; "$${CLEAN_ENV[@]}" "$$UV_BOOTSTRAP_VENV/bin/python" -m pip install "$${BOOTSTRAP_TOOLS[@]}"; "$${CLEAN_ENV[@]}" "$$UV_BOOTSTRAP_VENV/bin/python" -m pip install "$$UV_INSTALL_SPEC"; echo "$$UV_BOOTSTRAP_FINGERPRINT" > "$$UV_SPEC_FILE"; fi; UV_BIN="$$UV_BOOTSTRAP_VENV/bin/uv"; INSTALL_FINGERPRINT="vllm=$$VLLM_INSTALL_SPEC|pytorch=$$PYTORCH_INSTALL_SPEC|torch-backend=$$UV_TORCH_BACKEND|bootstrap-tools=$$PYTHON_BOOTSTRAP_TOOLS_SPEC|uv=$$UV_INSTALL_SPEC|nixpkgs=$$NIXPKGS_REV|exclude-newer=$${UV_EXCLUDE_NEWER:-none}"; if [ ! -x "$$VENV/bin/vllm" ] || [ ! -f "$$SPEC_FILE" ] || [ "$$(cat "$$SPEC_FILE" 2>/dev/null || true)" != "$$INSTALL_FINGERPRINT" ]; then echo "Creating/rebuilding pinned vLLM environment at $$VENV"; rm -rf "$$VENV"; "$${CLEAN_ENV[@]}" "$$UV_BIN" venv --python python3.12 "$$VENV"; UV_INSTALL_ARGS=(pip install --python "$$VENV/bin/python" --torch-backend="$$UV_TORCH_BACKEND" --exclude-newer "$$UV_EXCLUDE_NEWER"); "$${CLEAN_ENV[@]}" "$$UV_BIN" "$${UV_INSTALL_ARGS[@]}" 