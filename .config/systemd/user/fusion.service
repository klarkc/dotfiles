[Unit]
Description=Fusion dashboard
Documentation=https://github.com/Runfusion/Fusion
After=network-online.target
Wants=network-online.target

[Service]
WorkingDirectory=%h/Sources/Fusion
ExecStart=%h/.npm-packages/bin/fusion dashboard --host 0.0.0.0 --port 4040
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=default.target
