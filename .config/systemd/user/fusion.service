[Unit]
Description=Fusion dashboard
Documentation=https://github.com/Runfusion/Fusion
After=network-online.target
Wants=network-online.target

[Service]
Environment=NODE_LLAMA_CPP_SKIP_DOWNLOAD_GPU=1
Environment=GIT_CEILING_DIRECTORIES=%h/Sources/Fusion
Environment="GIT_SSH_COMMAND=ssh -F %h/.fusion/ssh_config"
Environment=FUSION_RUNTIME_DIR=%C/fusion-systemd
Environment=FUSION_NIX_CONFIG=%h/.config/nix/fusion-npm.nix
PassEnvironment=GITHUB_TOKEN FUSION_DASHBOARD_TOKEN FUSION_DAEMON_TOKEN VAST_API_KEY VLLM_API_KEY
WorkingDirectory=%h

RuntimeDirectory=fusion
RuntimeDirectoryMode=0700
CacheDirectory=fusion-systemd
CacheDirectoryMode=0700

ExecStart=/bin/sh -lc 'set -eu; nix_bin=""; for candidate in "$HOME/.nix-profile/bin/nix" /nix/var/nix/profiles/default/bin/nix /run/current-system/sw/bin/nix /usr/bin/nix; do if [ -x "$candidate" ]; then nix_bin="$candidate"; break; fi; done; if [ -z "$nix_bin" ]; then echo "nix executable not found" >&2; exit 127; fi; runtime="$FUSION_RUNTIME_DIR"; export XDG_CACHE_HOME="$runtime/xdg-cache"; mkdir -p "$runtime" "$XDG_CACHE_HOME"; fusion_store_path="$($nix_bin --extra-experimental-features "nix-command flakes" build --no-link --print-out-paths --file "$FUSION_NIX_CONFIG")"; socket="${XDG_RUNTIME_DIR:?XDG_RUNTIME_DIR is required}/fusion/tmux.sock"; session="fusion"; log="$runtime/dashboard.log"; cli=""; for candidate in "$fusion_store_path/bin/fusion" "$fusion_store_path/bin/fn"; do if [ -x "$candidate" ]; then cli="$candidate"; break; fi; done; if [ -z "$cli" ]; then echo "Fusion CLI not found in $fusion_store_path/bin" >&2; ls -la "$fusion_store_path/bin" >&2 || true; exit 127; fi; echo "Using Fusion CLI: $cli" >&2; "$cli" --version >&2 || true; "$fusion_store_path/bin/tmux" -S "$socket" kill-session -t "$session" 2>/dev/null || true; "$fusion_store_path/bin/tmux" -S "$socket" kill-server 2>/dev/null || true; rm -f "$socket"; : > "$log"; cmd="exec \"$cli\" dashboard --host 0.0.0.0 --port 4040 --no-auth 2>&1 | tee -a \"$log\""; "$fusion_store_path/bin/tmux" -S "$socket" new-session -d -s "$session" -c "$HOME/Sources/Fusion" "$cmd"; while "$fusion_store_path/bin/tmux" -S "$socket" has-session -t "$session" 2>/dev/null; do sleep 5; done; echo "Fusion tmux session exited; last dashboard log lines:" >&2; tail -n 120 "$log" >&2 || true; exit 1'
ExecStop=/bin/sh -lc 'set -eu; nix_bin=""; for candidate in "$HOME/.nix-profile/bin/nix" /nix/var/nix/profiles/default/bin/nix /run/current-system/sw/bin/nix /usr/bin/nix; do if [ -x "$candidate" ]; then nix_bin="$candidate"; break; fi; done; if [ -z "$nix_bin" ]; then echo "nix executable not found" >&2; exit 127; fi; runtime="$FUSION_RUNTIME_DIR"; export XDG_CACHE_HOME="$runtime/xdg-cache"; fusion_store_path="$($nix_bin --extra-experimental-features "nix-command flakes" build --no-link --print-out-paths --file "$FUSION_NIX_CONFIG")"; "$fusion_store_path/bin/tmux" -S "$XDG_RUNTIME_DIR/fusion/tmux.sock" kill-session -t fusion 2>/dev/null || true; "$fusion_store_path/bin/tmux" -S "$XDG_RUNTIME_DIR/fusion/tmux.sock" kill-server 2>/dev/null || true'

Restart=on-failure
RestartSec=5s

NoNewPrivileges=yes
RestrictSUIDSGID=yes
LockPersonality=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=read-only
ProtectControlGroups=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes

ReadOnlyPaths=%h/.config/nix/fusion-npm.nix
ReadWritePaths=%h/Sources/Fusion %h/.fusion %h/.pi %C/fusion-systemd %h/.config/qmd %t/fusion

[Install]
WantedBy=default.target
